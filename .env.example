# Required Discord bot token.
DISCORD_TOKEN=

# Gemini API configuration used by /ask and ModAI.
GEMINI_API_KEY=
MODAI_MODEL=gemini-2.5-flash
MODAI_FALLBACK_MODEL=gemini-2.0-flash
ASK_MODEL=gemini-2.5-flash
ASK_FALLBACK_MODEL=gemini-2.0-flash
ASK_ALLOWED_CHANNEL_IDS=
ASK_COOLDOWN_SECONDS=30

# Comma-separated Discord role IDs allowed to use restricted features.
MODAI_ALLOWED_ROLE_IDS=
STAFF_NOTES_ALLOWED_ROLE_IDS=
STATS_ALLOWED_ROLE_IDS=
VCSTATS_ALLOWED_ROLE_IDS=
BANK_ALLOWED_ROLE_IDS=

# Voice-channel XP pulse configuration.
VCXP_ENABLED=false
VCXP_TRIGGER_ROLE_ID=
VCXP_MINUTES_PER_PULSE=30
VCXP_ROLE_REMOVE_DELAY_SECONDS=30
VCXP_DAILY_PULSE_CAP=4
VCXP_WEEKLY_PULSE_CAP=20
