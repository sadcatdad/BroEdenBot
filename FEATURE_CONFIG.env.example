# Merge these names into Bro Eden's hosting environment using this server's
# own Discord IDs. Keep existing ENABLED_MODULES values and add the modules below.
ENABLED_MODULES=bumps,events,reminders,streaks,stats,visual

# Events uses Admin Dashboard Discord-role mappings rather than another environment
# role-ID list. Map Verified -> Verified Member and Captain -> Party Captain.
# Select the private forum, thread, or text channel in Admin Dashboard -> Features
# -> Events. This environment value is an optional bootstrap for the same picker.
EVENTS_ARTWORK_STORAGE_CHANNEL_ID=

# Shared permissions and optional private audit destination.
BOT_OWNER_USER_IDS=
AUDIT_LOG_THREAD_ID=

# Verified DISBOARD bumps and Bump Legends.
DISBOARD_BOT_USER_ID=
BUMP_REWARD_ROLE_ID=
BUMP_SUCCESS_ASSET_ID=
BUMP_PING_ROLE_ID=
BUMP_REMINDER_ASSET_ID=
BUMP_LEADERBOARD_CHANNEL_ID=
BUMP_POINTS_PER_SUCCESS=1000

# Reminder creation access and natural-language parsing fallback timezone.
REMINDER_ALLOWED_ROLE_IDS=
REMINDER_TIMEZONE=America/Chicago

# Daily message streaks.
STREAK_TIMEZONE=America/Chicago
STREAK_MIN_WORDS=4
STREAK_DUPLICATE_LOOKBACK_DAYS=30
STREAK_EXCLUDED_CHANNEL_IDS=
STREAK_EXCLUDED_CATEGORY_IDS=
STREAK_MILESTONE_CHANNEL_ID=
STREAK_MILESTONE_ASSET_ID=
STREAK_LEADERBOARD_CHANNEL_ID=
STREAK_RESTORE_ENABLED=true
STREAK_RESTORE_GAP_MINUTES=10
STREAK_RESTORE_MAX_DAYS=14
STREAK_RESTORE_MAX_MESSAGES=50000

# Stats role boards and leaderboard administration.
STATS_ALLOWED_ROLE_IDS=
LEADERBOARD_RESET_ROLE_IDS=

# Visual Content Studio persistent uploads and normalized renderer assets.
# The Admin Dashboard service needs read/write access; the bot service needs read access.
VISUAL_ASSET_DIR=/home/sadcatdad/BroEdenBot/data/visual-assets
VISUAL_RENDER_CONCURRENCY=2
# Existing private Discord forum post/thread used by Asset Library storage.
# Prefer saving this through Admin Dashboard -> Features -> Visual Content Studio.
VISUAL_ASSET_STORAGE_THREAD_ID=
# Existing private Discord forum post/thread used by member BROfile uploads.
# Prefer saving this through Admin Dashboard -> BROfile Management.
BROFILE_ASSET_STORAGE_THREAD_ID=
